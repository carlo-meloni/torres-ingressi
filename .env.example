# Neon PostgreSQL connection string.
# During development this points to the Neon DEVELOPMENT branch.
# Production uses a separate Neon branch (set in the deployment environment).
#
# Use the POOLED connection string (host contains "-pooler") for the app runtime.
# Example:
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.eu-central-1.aws.neon.tech/DBNAME?sslmode=require"
DATABASE_URL=""

# Initial SYSADMIN account created by `npm run db:seed` (on demand only).
# Change these before seeding a shared/production database.
SEED_ADMIN_EMAIL="admin@torres.local"
SEED_ADMIN_PASSWORD="changeme123"

# NextAuth v5 — secret used to sign/encrypt JWTs (generate: openssl rand -base64 33)
AUTH_SECRET=""

# Pusher — realtime della coda (dashboard cassa + schermo pubblico).
# Crea un'app su https://dashboard.pusher.com e copia le credenziali del Channels app.
# Senza queste chiavi il realtime è disattivato: l'app continua a funzionare via
# rivalidazione, ma gli aggiornamenti non vengono spinti alle altre schede.
# Lato server (segrete):
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER=""
# Lato client (esposte nel bundle; devono combaciare con KEY e CLUSTER qui sopra):
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER=""
