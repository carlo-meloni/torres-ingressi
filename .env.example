# Neon PostgreSQL connection string.
# During development this points to the Neon DEVELOPMENT branch.
# Production uses a separate Neon branch (set in the deployment environment).
#
# Use the POOLED connection string (host contains "-pooler") for the app runtime.
# Example:
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.eu-central-1.aws.neon.tech/DBNAME?sslmode=require"
DATABASE_URL=""

# Initial SYSADMIN account created by `npm run db:seed` (on demand only).
# Change these before seeding a shared/production database.
SEED_ADMIN_EMAIL="admin@torres.local"
SEED_ADMIN_PASSWORD="changeme123"
